# Database
# Connection string for Prisma ORM
# Example: postgresql://user:password@localhost:5432/feedback_fusion
DATABASE_URL=

# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk URLs (optional - customize if using custom domains)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/feedback
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/feedback
